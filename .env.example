APP_ENV=development
LOG_LEVEL=INFO

LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

# Data mode options: fixture | live
NEWS_DATA_MODE=fixture
PDF_DATA_MODE=fixture
PRICE_DATA_MODE=fixture

# Live price provider settings
# Expected endpoints:
#   GET {PRICE_LIVE_BASE_URL}/price?commodity=...&date=YYYY-MM-DD&benchmark=...
#   GET {PRICE_LIVE_BASE_URL}/trend?commodity=...&days=...&benchmark=...
# Both endpoints are expected to return the JSON structures used by lme-price-mcp.
# If you do not have a private API yet, the MCP can fall back to public commodity webpages.
PRICE_LIVE_BASE_URL=
PRICE_LIVE_API_KEY=
PRICE_LIVE_TIMEOUT_SECONDS=30
PRICE_PUBLIC_WEB_ENABLED=1
PRICE_PUBLIC_WEB_TIMEOUT_SECONDS=30
