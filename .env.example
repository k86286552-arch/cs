APP_ENV=development
LOG_LEVEL=INFO

LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

# Data mode options: fixture | live
NEWS_DATA_MODE=live
PDF_DATA_MODE=live
PRICE_DATA_MODE=live

# Live price provider settings
# Default real-world path: public website / public document scraping (no private API required)
# NEWS_DATA_MODE=live  -> RSS search + article extraction
# PDF_DATA_MODE=live   -> real PDF download + table/text extraction
# Keep PRICE_PUBLIC_WEB_ENABLED=1 and PRICE_DATA_MODE=live to use the public-web provider.
# Expected endpoints:
#   GET {PRICE_LIVE_BASE_URL}/price?commodity=...&date=YYYY-MM-DD&benchmark=...
#   GET {PRICE_LIVE_BASE_URL}/trend?commodity=...&days=...&benchmark=...
# Both endpoints are expected to return the JSON structures used by lme-price-mcp.
# A private API is optional. When omitted, the MCP will use public commodity webpages first.
PRICE_LIVE_BASE_URL=
PRICE_LIVE_API_KEY=
PRICE_LIVE_TIMEOUT_SECONDS=30
PRICE_PUBLIC_WEB_ENABLED=1
PRICE_PUBLIC_WEB_TIMEOUT_SECONDS=30
